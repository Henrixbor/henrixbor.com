            info.sessionTime = { label: 'Time on Page', value: `${(performance.now() / 1000).toFixed(1)}s` };

            // Returning visitor
            info.returning = { label: 'Visitor', value: detectReturningVisitor() };

            // Build the DOM
            const sections = [
                { label: 'Network', keys: ['ip', 'location', 'isp', 'latency'] },
                { label: 'System', keys: ['browser', 'os', 'screen', 'viewport', 'displayCaps'] },
                { label: 'Locale', keys: ['timezone', 'localTime', 'language'] },
                { label: 'Hardware', keys: ['cpu', 'gpu', 'touch', 'connection', 'battery', 'mediaDevices', 'gamepad'] },
                { label: 'Fingerprint', keys: ['prefs', 'canvasHash', 'audioHash', 'glExtensions', 'fonts', 'storage', 'sw'] },
                { label: 'Session', keys: ['referrer', 'sessionTime', 'returning'] },
