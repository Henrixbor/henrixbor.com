            // ── Run deductions engine ──
            await delay(300);
            const deductions = buildDeductions(info, ua);

            const dedSection = document.createElement('div');
            dedSection.className = 'deductions-section';
            dedSection.innerHTML = '<div class="deductions-label">Analysis</div>';
            body.appendChild(dedSection);

            for (const ded of deductions) {
                const row = document.createElement('div');
                row.className = 'deduction scanning';
                row.innerHTML = `<span class="deduction-icon">${ded.icon}</span><span class="deduction-text">analyzing...</span><span class="deduction-confidence"></span>`;
                dedSection.appendChild(row);
                await delay(120 + Math.random() * 80);
                row.querySelector('.deduction-text').textContent = ded.text;
                row.querySelector('.deduction-confidence').textContent = ded.confidence ? `, ${ded.confidence}%` : '';
                row.classList.remove('scanning');
                row.classList.add('revealed');
            }
        }

        // ── Deductions Engine ──
        function buildDeductions(info, ua) {
            const deds = [];
            const w = screen.width, h = screen.height;
            const dpr = window.devicePixelRatio || 1;
            const gpu = info.gpu.value;
            const cores = navigator.hardwareConcurrency || 0;
            const mem = navigator.deviceMemory || 0;
            const touch = navigator.maxTouchPoints;
            const hour = new Date().getHours();
            const day = new Date().getDay(); // 0=Sun
            const darkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
            const ipLocation = info.location.value;
            const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
            const incognito = detectIncognito();
            const adBlock = detectAdBlocker();
            const devSignals = detectDeveloper(ua, gpu);
            const botScore = detectBot(ua);
            const tier = estimateDeviceTier(cores, mem, dpr, gpu, w, h);
            const langs = navigator.languages || [navigator.language];
            const vpnResult = (ipLocation && ipLocation !== 'Blocked' && ipLocation !== '...') ? detectVPN(tz, ipLocation) : { detected: false };

            // ── Device identification ──
            const device = identifyDevice(w, h, dpr, gpu, ua, touch);
            if (device) deds.push({ icon: '\u{1F4F1}', text: `Likely device: ${device.name}`, confidence: device.confidence });

            // ── Device tier ──
            deds.push({ icon: '\u{1F4B0}', text: `Device tier: ${tier.label}`, confidence: tier.confidence });

            // ── Bot detection (show early if bot) ──
            if (botScore.isBot) {
                deds.push({ icon: '\u{1F916}', text: `Automated browser detected (${botScore.reason})`, confidence: botScore.confidence });
            }

            // ── VPN / proxy ──
            if (vpnResult.detected) {
                deds.push({ icon: '\u{1F6E1}', text: 'VPN or proxy likely active (timezone/IP mismatch)', confidence: vpnResult.confidence });
            }

            // ── Incognito ──
            if (incognito) deds.push({ icon: '\u{1F576}', text: 'Private/incognito mode detected', confidence: 70 });

            // ── Ad blocker ──
            deds.push({ icon: adBlock ? '\u{1F6AB}' : '\u{1F4E2}',
                text: adBlock ? 'Ad blocker active' : 'No ad blocker — you see all the ads',
                confidence: adBlock ? 90 : 70 });

            // ── Developer detection ──
