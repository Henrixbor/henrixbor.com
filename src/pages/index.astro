---
const title = "Henri Kamarainen";
const tagline = "Builder · Adventurer · AI Enthusiast";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={tagline}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #08080a;
            --text: #fafafa;
            --text-secondary: #a1a1aa;
            --text-tertiary: #52525b;
            --surface: #14141a;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            min-height: 100vh;
            overflow: hidden;
        }

        /* Dot grid canvas */
        #dotGrid {
            position: fixed;
            inset: 0;
            z-index: 0;
        }

        /* Subtle noise overlay */
        .noise {
            position: fixed;
            inset: -50%;
            width: 200%;
            height: 200%;
            pointer-events: none;
            z-index: 1;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            animation: grain 8s steps(10) infinite;
        }

        @keyframes grain {
            0%, 100% { transform: translate(0, 0); }
            10% { transform: translate(-5%, -10%); }
            30% { transform: translate(3%, -15%); }
            50% { transform: translate(12%, 9%); }
            70% { transform: translate(9%, 4%); }
            90% { transform: translate(-1%, 7%); }
        }

        /* Content */
        .content {
            position: fixed;
            inset: 0;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }

        .inner {
            text-align: center;
            padding: 2rem;
            pointer-events: auto;
        }

        .avatar-wrapper {
            margin-bottom: 1.5rem;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .avatar {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            object-fit: cover;
            filter: grayscale(1) contrast(1.1) brightness(0.9);
            opacity: 0.7;
            border: 2px solid rgba(167, 139, 250, 0.15);
            transition: filter 0.5s, opacity 0.5s, border-color 0.5s;
        }

        .avatar:hover {
            filter: grayscale(0.3) contrast(1.05) brightness(1);
            opacity: 1;
            border-color: rgba(167, 139, 250, 0.4);
        }

        .intro {
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
        }

        .name {
            font-size: 2.2rem;
            font-weight: 500;
            letter-spacing: -0.04em;
            line-height: 1.1;
            color: var(--text);
        }

        .role {
            font-size: 0.9375rem;
            color: var(--text-secondary);
            margin-top: 0.75rem;
            font-weight: 300;
            letter-spacing: 0.02em;
        }

        .divider {
            width: 32px;
            height: 1px;
            background: #27272a;
            margin: 2rem auto;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
        }

        .links {
            display: flex;
            gap: 0.25rem;
            justify-content: center;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
        }

        .links a {
            color: var(--text-tertiary);
            text-decoration: none;
            font-size: 0.8125rem;
            font-weight: 400;
            letter-spacing: 0.01em;
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            transition: color 0.3s, background 0.3s;
            position: relative;
        }

        .links a:hover {
            color: var(--text);
            background: var(--surface);
        }

        /* Scramble chars get a dim style */
        .scramble-glyph {
            color: var(--text-tertiary);
            opacity: 0.5;
        }

        .dot {
            color: var(--text-tertiary);
            opacity: 0.3;
            align-self: center;
            font-size: 0.5rem;
        }

        @keyframes enter {
            from {
                opacity: 0;
                transform: translateY(16px);
                filter: blur(6px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
                filter: blur(0);
            }
        }

        /* Mobile: avatar always slightly revealed */
        @media (hover: none) {
            .avatar {
                filter: grayscale(0.5) contrast(1.05) brightness(0.95);
                opacity: 0.85;
                border-color: rgba(167, 139, 250, 0.3);
            }
        }

        /* Gyro permission prompt */
        .gyro-prompt {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            background: rgba(167, 139, 250, 0.1);
            border: 1px solid rgba(167, 139, 250, 0.2);
            color: var(--text-secondary);
            font-family: 'Inter', system-ui, sans-serif;
            font-size: 0.75rem;
            font-weight: 400;
            letter-spacing: 0.02em;
            padding: 0.6rem 1.2rem;
            border-radius: 100px;
            cursor: pointer;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.8s both;
            transition: opacity 0.4s, transform 0.4s;
        }

        .gyro-prompt:active {
            transform: translateX(-50%) scale(0.96);
        }

        .gyro-prompt.hidden {
            opacity: 0;
            transform: translateX(-50%) translateY(8px);
            pointer-events: none;
        }

        @media (max-width: 480px) {
            .name { font-size: 1.6rem; }
            .inner { padding: 1.5rem; }
        }

        /* ─── "I see you" eye ─── */
        .see-wrapper {
            margin-top: 2rem;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
        }
        .see-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 1px solid rgba(167, 139, 250, 0.1);
            background: transparent;
            color: var(--text-tertiary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                        border-color 0.4s,
                        box-shadow 0.4s;
        }
        .see-btn svg.eye-outline {
            width: 24px;
            height: 24px;
            opacity: 0.3;
            transition: opacity 0.4s, stroke 0.4s;
            overflow: visible;
        }
        .see-btn .eye-pupil {
            transition: fill 0.4s;
        }

        /* Glow ring */
        .see-btn::before {
            content: '';
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            border: 1px solid rgba(167, 139, 250, 0);
            transition: border-color 0.4s, transform 0.4s;
            pointer-events: none;
        }

        /* Activated state via JS */
        .see-btn.eye-near {
            transform: scale(1.3);
            border-color: rgba(167, 139, 250, 0.4);
            box-shadow: 0 0 30px rgba(167, 139, 250, 0.15),
                        0 0 60px rgba(167, 139, 250, 0.05);
        }
        .see-btn.eye-near svg.eye-outline {
            opacity: 1;
            stroke: #a78bfa;
        }
        .see-btn.eye-near .eye-pupil {
            fill: #a78bfa;
        }
        .see-btn.eye-near::before {
            border-color: rgba(167, 139, 250, 0.2);
            transform: scale(1.3);
        }

        /* Extra close — pulsing intensely */
        .see-btn.eye-locked {
            transform: scale(1.5);
            border-color: rgba(167, 139, 250, 0.7);
            box-shadow: 0 0 40px rgba(167, 139, 250, 0.3),
                        0 0 80px rgba(167, 139, 250, 0.1),
                        inset 0 0 15px rgba(167, 139, 250, 0.05);
            animation: eyePulse 0.8s ease-in-out infinite;
        }
        .see-btn.eye-locked::before {
            border-color: rgba(167, 139, 250, 0.4);
            transform: scale(1.6);
        }

        @keyframes eyePulse {
            0%, 100% { box-shadow: 0 0 40px rgba(167, 139, 250, 0.3), 0 0 80px rgba(167, 139, 250, 0.1); }
            50% { box-shadow: 0 0 50px rgba(167, 139, 250, 0.5), 0 0 100px rgba(167, 139, 250, 0.2); }
        }

        /* Hover fallback for desktop without gyro */
        .see-btn:hover {
            border-color: rgba(167, 139, 250, 0.3);
        }
        .see-btn:hover svg.eye-outline {
            opacity: 0.8;
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 100;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s;
        }
        .modal-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }

        .modal {
            background: #0c0c10;
            border: 1px solid #1e1e28;
            border-radius: 12px;
            width: 92vw;
            max-width: 480px;
            max-height: 88vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transform: translateY(20px) scale(0.96);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
            position: relative;
        }
        .modal-map {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0;
            transition: opacity 2s ease;
            border-radius: 12px;
            overflow: hidden;
        }
        .modal-map.visible {
            opacity: 0.85;
        }
        /* No separate overlay — darkening applied via content layer background */
        /* Purple-tinted map with visible lines */
        .modal-map .leaflet-tile-pane {
            filter: brightness(1) saturate(0.5) hue-rotate(40deg) contrast(1.3);
        }
        /* Hide Leaflet controls & attribution */
        .modal-map .leaflet-control-container { display: none; }
        /* GPS dot — rendered above content layer */
        .map-gps-dot {
            position: absolute;
            z-index: 5;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.6s ease;
        }
        .map-gps-dot.visible { opacity: 1; }
        /* GPS-style neon marker (children of .map-gps-dot) */
        .map-marker-dot {
            position: absolute;
            top: 0; left: 0;
            transform: translate(-50%, -50%);
            width: 12px; height: 12px;
            background: #a78bfa;
            border-radius: 50%;
            z-index: 3;
            animation: dotGlow 3s ease-in-out infinite;
        }
        @keyframes dotGlow {
            0%, 100% {
                box-shadow: 0 0 8px #a78bfa, 0 0 20px rgba(167,139,250,0.5), 0 0 40px rgba(167,139,250,0.2);
            }
            50% {
                box-shadow: 0 0 14px #c4b5fd, 0 0 35px rgba(167,139,250,0.7), 0 0 60px rgba(167,139,250,0.35);
            }
        }
        .map-marker-ring {
            position: absolute;
            top: 0; left: 0;
            border: 1.5px solid rgba(167,139,250,0.5);
            border-radius: 50%;
            animation: mapRing 3s ease-out infinite;
        }
        .map-marker-ring2 {
            position: absolute;
            top: 0; left: 0;
            border: 1px solid rgba(167,139,250,0.3);
            border-radius: 50%;
            animation: mapRing 3s ease-out 1.5s infinite;
        }
        @keyframes mapRing {
            0% { width: 12px; height: 12px; transform: translate(-50%, -50%); opacity: 0.8; }
            100% { width: 80px; height: 80px; transform: translate(-50%, -50%); opacity: 0; }
        }
        .modal-content-layer {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            max-height: 88vh;
            overflow: hidden;
            background:
                linear-gradient(180deg, rgba(12,12,16,0.88) 0%, rgba(12,12,16,0.7) 35%, rgba(12,12,16,0.85) 100%);
            border-radius: 12px;
        }
        .modal-overlay.open .modal {
            transform: translateY(0) scale(1);
        }

        .modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.7rem 1rem;
            border-bottom: 1px solid #1e1e28;
            flex-shrink: 0;
        }
        .modal-title {
            font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
            font-size: 0.7rem;
            font-weight: 500;
            color: var(--text-secondary);
            letter-spacing: 0.05em;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .modal-subtitle {
            font-size: 0.55rem;
            font-weight: 400;
            color: var(--text-tertiary);
            text-transform: none;
            letter-spacing: 0.02em;
            margin-left: 0.15rem;
        }
        .modal-title .pulse {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #a78bfa;
            animation: pulse 2s ease-in-out infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 1; }
        }
        .modal-close {
            background: none;
            border: none;
            color: var(--text-tertiary);
            cursor: pointer;
            padding: 0.25rem;
            border-radius: 4px;
            transition: color 0.2s, background 0.2s;
            font-size: 1.1rem;
            line-height: 1;
        }
        .modal-close:hover {
            color: var(--text);
            background: rgba(255,255,255,0.05);
        }

        .modal-body {
            padding: 0.75rem 1rem;
            overflow-y: auto;
            font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
            font-size: 0.65rem;
            line-height: 1.5;
            color: var(--text-secondary);
            scrollbar-width: thin;
            scrollbar-color: #27272a transparent;
        }
        .modal-body::-webkit-scrollbar { width: 4px; }
        .modal-body::-webkit-scrollbar-track { background: transparent; }
        .modal-body::-webkit-scrollbar-thumb { background: #27272a; border-radius: 2px; }

        .info-section {
            padding: 0.5rem 0;
        }
        .info-section + .info-section {
            border-top: 1px solid #1a1a24;
        }
        .section-label {
            color: #a78bfa;
            font-size: 0.6rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 0.35rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .section-label::before {
            content: '>';
            opacity: 0.5;
        }
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: 0.1rem 0 0.1rem 0.85rem;
            gap: 0.75rem;
        }
        .info-key {
            color: var(--text-tertiary);
            white-space: nowrap;
            flex-shrink: 0;
        }
        .info-val {
            color: var(--text);
            text-align: right;
            word-break: break-all;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .info-val.revealed { opacity: 1; }
        .info-val.scanning {
            color: #a78bfa;
            opacity: 0.5;
        }

        /* Deductions section */
        .deductions-section {
            padding: 0.6rem 0 0.3rem;
            border-top: 1px solid #a78bfa22;
        }
        .deductions-label {
            color: #c4b5fd;
            font-size: 0.6rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 0.4rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .deductions-label::before {
            content: '>';
            opacity: 0.5;
        }
        .deduction {
            padding: 0.2rem 0 0.2rem 0.85rem;
            color: var(--text);
            opacity: 0;
            transition: opacity 0.4s;
            display: flex;
            align-items: baseline;
            gap: 0.5rem;
        }
        .deduction.revealed { opacity: 1; }
        .deduction.scanning {
            color: #a78bfa;
            opacity: 0.4;
        }
        .deduction-icon {
            flex-shrink: 0;
            font-size: 0.55rem;
            opacity: 0.6;
        }
        .deduction-text {
            flex: 1;
        }
        .deduction-confidence {
            color: var(--text-tertiary);
            font-size: 0.55rem;
            flex-shrink: 0;
        }

        .modal-footer {
            padding: 0.5rem 1rem;
            border-top: 1px solid #1e1e28;
            font-family: 'SF Mono', monospace;
            font-size: 0.55rem;
            color: var(--text-tertiary);
            text-align: center;
            letter-spacing: 0.02em;
            flex-shrink: 0;
        }

        @media (max-width: 480px) {
            .modal { max-height: 92vh; }
            .modal-body { font-size: 0.6rem; padding: 0.5rem 0.75rem; }
            .info-row { padding-left: 0.6rem; }
        }
    </style>
</head>
<body>
    <canvas id="dotGrid"></canvas>
    <div class="noise"></div>
    <button class="gyro-prompt" id="gyroPrompt" style="display:none;">Tap to enable tilt interaction</button>

    <!-- Modal overlay -->
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal">
            <div id="modalMap" class="modal-map"></div>
            <div id="mapGpsDot" class="map-gps-dot">
                <div class="map-marker-dot"></div>
                <div class="map-marker-ring"></div>
                <div class="map-marker-ring2"></div>
            </div>
            <div class="modal-content-layer">
                <div class="modal-header">
                    <div class="modal-title"><span class="pulse"></span> scanning visitor <span class="modal-subtitle">every website sees this</span></div>
                    <button class="modal-close" id="modalClose">&times;</button>
                </div>
                <div class="modal-body" id="modalBody"></div>
                <div class="modal-footer">all data collected client-side &middot; nothing is stored</div>
            </div>
        </div>
    </div>
    <div class="content">
        <div class="inner">
            <div class="avatar-wrapper">
                <img src="/photo.jpg" alt="Henri Kamarainen" class="avatar" width="96" height="96">
            </div>
            <div class="intro">
                <h1 class="name" data-scramble data-text={title}>{title}</h1>
                <p class="role" data-scramble data-text={tagline}>{tagline}</p>
            </div>
            <div class="divider"></div>
            <nav class="links">
                <a href="https://github.com/Henrixbor" target="_blank" rel="noopener" data-scramble data-text="GitHub">GitHub</a>
                <span class="dot">&#9679;</span>
                <a href="https://linkedin.com/in/kamarainen" target="_blank" rel="noopener" data-scramble data-text="LinkedIn">LinkedIn</a>
                <span class="dot">&#9679;</span>
                <a href="mailto:henkka.kamarainen@gmail.com" data-scramble data-text="Email">Email</a>
            </nav>
            <div class="see-wrapper">
                <button class="see-btn" id="seeBtn" title="What do I know about you?">
                    <svg class="eye-outline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle class="eye-iris" id="eyeIris" cx="12" cy="12" r="3" fill="none"/>
                        <circle class="eye-pupil" id="eyePupil" cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <script>
    // ─── Shared pointer position (used by dot grid + scramble proximity) ──
    const pointer = { x: -1000, y: -1000 };
    const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

    // ─── Gyro Ball (mobile) ─────────────────────────────────────
    const gyroBall = {
        x: -1000, y: -1000,
        vx: 0, vy: 0,
        active: false,
        gravity: 0.8,
        friction: 0.975,
        bounce: 0.35,
        refBeta: null,      // neutral holding angle (captured on init)
        refGamma: null,
    };

    function updateGyroBall() {
        if (!gyroBall.active) return;

        const w = window.innerWidth;
        const h = window.innerHeight;

        gyroBall.vx *= gyroBall.friction;
        gyroBall.vy *= gyroBall.friction;
        gyroBall.x += gyroBall.vx;
        gyroBall.y += gyroBall.vy;

        // Bounce off walls
        if (gyroBall.x < 0) { gyroBall.x = 0; gyroBall.vx *= -gyroBall.bounce; }
        if (gyroBall.x > w) { gyroBall.x = w; gyroBall.vx *= -gyroBall.bounce; }
        if (gyroBall.y < 0) { gyroBall.y = 0; gyroBall.vy *= -gyroBall.bounce; }
        if (gyroBall.y > h) { gyroBall.y = h; gyroBall.vy *= -gyroBall.bounce; }

        pointer.x = gyroBall.x;
        pointer.y = gyroBall.y;
    }

    function handleOrientation(e) {
        if (!gyroBall.active) return;

        const beta = e.beta || 0;
        const gamma = e.gamma || 0;

        // Capture the user's natural holding angle as reference
        if (gyroBall.refBeta === null) {
            gyroBall.refBeta = beta;
            gyroBall.refGamma = gamma;
            return;
        }

        // Delta from neutral position — tilt relative to how you're holding it
        let dBeta = beta - gyroBall.refBeta;
        let dGamma = gamma - gyroBall.refGamma;

        // Clamp deltas
        const MAX_TILT = 30;
        dBeta = Math.max(-MAX_TILT, Math.min(MAX_TILT, dBeta));
        dGamma = Math.max(-MAX_TILT, Math.min(MAX_TILT, dGamma));

        // Map tilt delta to acceleration (gamma = X, beta = Y)
        gyroBall.vx += (dGamma / MAX_TILT) * gyroBall.gravity;
        gyroBall.vy += (dBeta / MAX_TILT) * gyroBall.gravity;
    }

    async function initGyro() {
        gyroBall.x = window.innerWidth / 2;
        gyroBall.y = window.innerHeight / 2;
        gyroBall.refBeta = null;  // will capture on first orientation event
        gyroBall.refGamma = null;
        gyroBall.active = true;

        window.addEventListener('deviceorientation', handleOrientation);
    }

    // Show gyro prompt on touch devices
    if (isTouchDevice) {
        const prompt = document.getElementById('gyroPrompt');
        const needsPermission = typeof DeviceOrientationEvent !== 'undefined'
            && typeof DeviceOrientationEvent.requestPermission === 'function';

        // Only show prompt if gyro might be available
        if (typeof DeviceOrientationEvent !== 'undefined') {
            prompt.style.display = '';

            prompt.addEventListener('click', async () => {
                if (needsPermission) {
                    try {
                        const result = await DeviceOrientationEvent.requestPermission();
                        if (result === 'granted') {
                            await initGyro();
                        }
                    } catch (err) {
                        // Permission denied or unavailable
                    }
                } else {
                    await initGyro();
                }
                prompt.classList.add('hidden');
            });
        }
    }

    // ─── Interactive Dot Grid ───────────────────────────────────
    (function() {
        const canvas = document.getElementById('dotGrid');
        const ctx = canvas.getContext('2d');

        const DOT_SPACING = 28;
        const DOT_RADIUS = 1.2;
        const INFLUENCE_RADIUS = 150;
        const MAX_DISPLACEMENT = 20;
        const SPRING = 0.06;
        const DAMPING = 0.82;
        const BASE_ALPHA = 0.2;
        const HOVER_ALPHA = 0.9;

        const BASE_R = 113, BASE_G = 113, BASE_B = 122;
        const HOVER_R = 167, HOVER_G = 139, HOVER_B = 250;

        const GLOW_DECAY = 0.99;  // ~2 second fade trail

        let dots = [];
        let w, h;

        function init() {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
            dots = [];

            const cols = Math.ceil(w / DOT_SPACING) + 2;
            const rows = Math.ceil(h / DOT_SPACING) + 2;
            const offsetX = (w - (cols - 1) * DOT_SPACING) / 2;
            const offsetY = (h - (rows - 1) * DOT_SPACING) / 2;

            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    dots.push({
                        ox: offsetX + c * DOT_SPACING,
                        oy: offsetY + r * DOT_SPACING,
                        x: offsetX + c * DOT_SPACING,
                        y: offsetY + r * DOT_SPACING,
                        vx: 0,
                        vy: 0,
                        glow: 0,  // persistent glow intensity (0-1)
                    });
                }
            }
        }

        function animate() {
            // Update gyro ball physics each frame
            updateGyroBall();

            ctx.clearRect(0, 0, w, h);

            for (let i = 0; i < dots.length; i++) {
                const d = dots[i];
                const dx = pointer.x - d.ox;
                const dy = pointer.y - d.oy;
                const dist = Math.sqrt(dx * dx + dy * dy);

                if (dist < INFLUENCE_RADIUS) {
                    const force = (1 - dist / INFLUENCE_RADIUS);
                    const forceSq = force * force;
                    const angle = Math.atan2(dy, dx);
                    const push = forceSq * MAX_DISPLACEMENT;
                    d.vx += (-Math.cos(angle) * push - (d.x - d.ox)) * SPRING;
                    d.vy += (-Math.sin(angle) * push - (d.y - d.oy)) * SPRING;
                } else {
                    d.vx += (d.ox - d.x) * SPRING;
                    d.vy += (d.oy - d.y) * SPRING;
                }

                d.vx *= DAMPING;
                d.vy *= DAMPING;
                d.x += d.vx;
                d.y += d.vy;

                const liveProximity = dist < INFLUENCE_RADIUS
                    ? Math.pow(1 - dist / INFLUENCE_RADIUS, 1.5)
                    : 0;

                // Update persistent glow: ramp up instantly, decay slowly
                if (liveProximity > d.glow) {
                    d.glow = liveProximity;
                } else {
                    d.glow *= GLOW_DECAY;
                    if (d.glow < 0.005) d.glow = 0;
                }

                // Use whichever is stronger: live proximity or lingering glow
                const proximity = Math.max(liveProximity, d.glow);

                const r = Math.round(BASE_R + (HOVER_R - BASE_R) * proximity);
                const g = Math.round(BASE_G + (HOVER_G - BASE_G) * proximity);
                const b = Math.round(BASE_B + (HOVER_B - BASE_B) * proximity);
                const alpha = BASE_ALPHA + (HOVER_ALPHA - BASE_ALPHA) * proximity;
                const radius = DOT_RADIUS + proximity * 1.2;

                ctx.beginPath();
                ctx.arc(d.x, d.y, radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
                ctx.fill();
            }

            requestAnimationFrame(animate);
        }

        // Desktop: mouse events
        window.addEventListener('mousemove', (e) => {
            pointer.x = e.clientX;
            pointer.y = e.clientY;
        });

        window.addEventListener('mouseleave', () => {
            pointer.x = -1000;
            pointer.y = -1000;
        });

        // Mobile: touch fallback (works alongside or without gyro)
        window.addEventListener('touchmove', (e) => {
            if (!gyroBall.active) {
                pointer.x = e.touches[0].clientX;
                pointer.y = e.touches[0].clientY;
            }
        }, { passive: true });

        window.addEventListener('touchend', () => {
            if (!gyroBall.active) {
                pointer.x = -1000;
                pointer.y = -1000;
            }
        });

        window.addEventListener('resize', init);
        init();
        animate();
    })();

    // ─── Text Scramble ──────────────────────────────────────────
    (function() {
        const GLYPHS = '!<>-_\\/[]{}—=+*^?#________';

        class Scramble {
            constructor(el) {
                this.el = el;
                this.originalText = el.dataset.text;
                this.queue = [];
                this.frame = 0;
                this.running = false;
                this.raf = null;
            }

            scrambleTo(text) {
                const current = this.el.textContent;
                const len = Math.max(current.length, text.length);
                this.queue = [];

                for (let i = 0; i < len; i++) {
                    const from = current[i] || '';
                    const to = text[i] || '';
                    const start = Math.floor(Math.random() * 15);
                    const end = start + Math.floor(Math.random() * 25) + 5;
                    this.queue.push({ from, to, start, end, char: null });
                }

                cancelAnimationFrame(this.raf);
                this.frame = 0;
                this.running = true;
                this.tick();
            }

            tick() {
                let output = '';
                let done = 0;

                for (let i = 0; i < this.queue.length; i++) {
                    const q = this.queue[i];

                    if (this.frame >= q.end) {
                        done++;
                        output += q.to;
                    } else if (this.frame >= q.start) {
                        if (!q.char || Math.random() < 0.3) {
                            q.char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                        }
                        output += `<span class="scramble-glyph">${q.char}</span>`;
                    } else {
                        output += q.from;
                    }
                }

                this.el.innerHTML = output;
                this.frame++;

                if (done < this.queue.length) {
                    this.raf = requestAnimationFrame(() => this.tick());
                } else {
                    this.running = false;
                }
            }

            reset() {
                cancelAnimationFrame(this.raf);
                this.running = false;
                this.el.textContent = this.originalText;
            }
        }

        const scramblers = [];

        document.querySelectorAll('[data-scramble]').forEach(el => {
            const s = new Scramble(el);
            scramblers.push(s);

            // Desktop: hover scramble
            el.addEventListener('mouseenter', () => {
                s.scrambleTo(s.originalText);
            });

            el.addEventListener('mouseleave', () => {
                if (!s.running) s.reset();
            });
        });

        // Entrance scramble on load (all devices)
        setTimeout(() => {
            scramblers.forEach((s, i) => {
                setTimeout(() => s.scrambleTo(s.originalText), i * 120);
            });
        }, 400);

        // Proximity-based scramble trigger for gyro ball / touch
        if (isTouchDevice) {
            let lastTriggered = new Map();

            function checkProximityScramble() {
                scramblers.forEach(s => {
                    const rect = s.el.getBoundingClientRect();
                    const cx = rect.left + rect.width / 2;
                    const cy = rect.top + rect.height / 2;
                    const dx = pointer.x - cx;
                    const dy = pointer.y - cy;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    const now = Date.now();
                    const last = lastTriggered.get(s) || 0;

                    if (dist < 100 && now - last > 1500) {
                        s.scrambleTo(s.originalText);
                        lastTriggered.set(s, now);
                    }
                });

                requestAnimationFrame(checkProximityScramble);
            }
            checkProximityScramble();
        }
    })();

    // ─── Eye Tracking & Proximity ────────────────────────────────
    (function() {
        const eyeBtn = document.getElementById('seeBtn');
        const pupil = document.getElementById('eyePupil');
        const iris = document.getElementById('eyeIris');
        const EYE_NEAR_DIST = 180;
        const EYE_LOCK_DIST = 70;
        const IRIS_MAX_OFFSET = 2.0;
        const PUPIL_MAX_OFFSET = 2.8;
        let eyeLockedTime = 0;
        let eyeAutoTriggered = false;

        function updateEye() {
            const rect = eyeBtn.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const dx = pointer.x - cx;
            const dy = pointer.y - cy;
            const dist = Math.sqrt(dx * dx + dy * dy);

            // Iris + pupil tracking — both follow pointer, pupil moves further
            if (pointer.x > -500) {
                const angle = Math.atan2(dy, dx);
                const strength = Math.min(1, dist / 200);
                const iox = Math.cos(angle) * IRIS_MAX_OFFSET * strength;
                const ioy = Math.sin(angle) * IRIS_MAX_OFFSET * strength;
                const pox = Math.cos(angle) * PUPIL_MAX_OFFSET * strength;
                const poy = Math.sin(angle) * PUPIL_MAX_OFFSET * strength;
                iris.setAttribute('cx', 12 + iox);
                iris.setAttribute('cy', 12 + ioy);
                pupil.setAttribute('cx', 12 + pox);
                pupil.setAttribute('cy', 12 + poy);
            } else {
                iris.setAttribute('cx', 12);
                iris.setAttribute('cy', 12);
                pupil.setAttribute('cx', 12);
                pupil.setAttribute('cy', 12);
            }

            // Proximity states
            if (dist < EYE_LOCK_DIST) {
                eyeBtn.classList.add('eye-near', 'eye-locked');
                eyeLockedTime += 16;
                // Auto-open after hovering ~1.2s
                if (eyeLockedTime > 1200 && !eyeAutoTriggered && !document.getElementById('modalOverlay').classList.contains('open')) {
                    eyeAutoTriggered = true;
                    eyeBtn.click();
                }
            } else if (dist < EYE_NEAR_DIST) {
                eyeBtn.classList.add('eye-near');
                eyeBtn.classList.remove('eye-locked');
                eyeLockedTime = 0;
                eyeAutoTriggered = false;
            } else {
                eyeBtn.classList.remove('eye-near', 'eye-locked');
                eyeLockedTime = 0;
                eyeAutoTriggered = false;
            }

            requestAnimationFrame(updateEye);
        }
        updateEye();
    })();

    // ─── "I See You" Modal ───────────────────────────────────────
    (function() {
        const overlay = document.getElementById('modalOverlay');
        const body = document.getElementById('modalBody');
        const btn = document.getElementById('seeBtn');
        const closeBtn = document.getElementById('modalClose');

        function close() {
            overlay.classList.remove('open');
            scanRunning = false;
            const mapEl = document.getElementById('modalMap');
            const gpsDot = document.getElementById('mapGpsDot');
            if (mapEl) mapEl.classList.remove('visible');
            if (gpsDot) gpsDot.classList.remove('visible');
            if (mapAnimFrame) { cancelAnimationFrame(mapAnimFrame); mapAnimFrame = null; }
            if (modalMapInstance) { modalMapInstance.remove(); modalMapInstance = null; }
        }
        closeBtn.addEventListener('click', close);
        overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

        let scanRunning = false;
        btn.addEventListener('click', async () => {
            if (scanRunning) return;
            scanRunning = true;
