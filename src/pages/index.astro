---
const title = "Henri Kamarainen";
const tagline = "Builder · Adventurer · AI Enthusiast";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={tagline}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #08080a;
            --text: #fafafa;
            --text-secondary: #a1a1aa;
            --text-tertiary: #52525b;
            --surface: #14141a;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            min-height: 100vh;
            overflow: hidden;
        }

        /* Dot grid canvas */
        #dotGrid {
            position: fixed;
            inset: 0;
            z-index: 0;
        }

        /* Subtle noise overlay */
        .noise {
            position: fixed;
            inset: -50%;
            width: 200%;
            height: 200%;
            pointer-events: none;
            z-index: 1;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            animation: grain 8s steps(10) infinite;
        }

        @keyframes grain {
            0%, 100% { transform: translate(0, 0); }
            10% { transform: translate(-5%, -10%); }
            30% { transform: translate(3%, -15%); }
            50% { transform: translate(12%, 9%); }
            70% { transform: translate(9%, 4%); }
            90% { transform: translate(-1%, 7%); }
        }

        /* Content */
        .content {
            position: fixed;
            inset: 0;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }

        .inner {
            text-align: center;
            padding: 2rem;
            pointer-events: auto;
        }

        .avatar-wrapper {
            margin-bottom: 1.5rem;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .avatar {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            object-fit: cover;
            filter: grayscale(1) contrast(1.1) brightness(0.9);
            opacity: 0.7;
            border: 2px solid rgba(167, 139, 250, 0.15);
            transition: filter 0.5s, opacity 0.5s, border-color 0.5s;
        }

        .avatar:hover {
            filter: grayscale(0.3) contrast(1.05) brightness(1);
            opacity: 1;
            border-color: rgba(167, 139, 250, 0.4);
        }

        .intro {
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
        }

        .name {
            font-size: 2.2rem;
            font-weight: 500;
            letter-spacing: -0.04em;
            line-height: 1.1;
            color: var(--text);
        }

        .role {
            font-size: 0.9375rem;
            color: var(--text-secondary);
            margin-top: 0.75rem;
            font-weight: 300;
            letter-spacing: 0.02em;
        }

        .divider {
            width: 32px;
            height: 1px;
            background: #27272a;
            margin: 2rem auto;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
        }

        .links {
            display: flex;
            gap: 0.25rem;
            justify-content: center;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
        }

        .links a {
            color: var(--text-tertiary);
            text-decoration: none;
            font-size: 0.8125rem;
            font-weight: 400;
            letter-spacing: 0.01em;
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            transition: color 0.3s, background 0.3s;
            position: relative;
        }

        .links a:hover {
            color: var(--text);
            background: var(--surface);
        }

        /* Scramble chars get a dim style */
        .scramble-glyph {
            color: var(--text-tertiary);
            opacity: 0.5;
        }

        .dot {
            color: var(--text-tertiary);
            opacity: 0.3;
            align-self: center;
            font-size: 0.5rem;
        }

        @keyframes enter {
            from {
                opacity: 0;
                transform: translateY(16px);
                filter: blur(6px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
                filter: blur(0);
            }
        }

        /* Mobile: avatar always slightly revealed */
        @media (hover: none) {
            .avatar {
                filter: grayscale(0.5) contrast(1.05) brightness(0.95);
                opacity: 0.85;
                border-color: rgba(167, 139, 250, 0.3);
            }
        }

        /* Gyro permission prompt */
        .gyro-prompt {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            background: rgba(167, 139, 250, 0.1);
            border: 1px solid rgba(167, 139, 250, 0.2);
            color: var(--text-secondary);
            font-family: 'Inter', system-ui, sans-serif;
            font-size: 0.75rem;
            font-weight: 400;
            letter-spacing: 0.02em;
            padding: 0.6rem 1.2rem;
            border-radius: 100px;
            cursor: pointer;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.8s both;
            transition: opacity 0.4s, transform 0.4s;
        }

        .gyro-prompt:active {
            transform: translateX(-50%) scale(0.96);
        }

        .gyro-prompt.hidden {
            opacity: 0;
            transform: translateX(-50%) translateY(8px);
            pointer-events: none;
        }

        @media (max-width: 480px) {
            .name { font-size: 1.6rem; }
            .inner { padding: 1.5rem; }
        }
    </style>
</head>
<body>
    <canvas id="dotGrid"></canvas>
    <div class="noise"></div>
    <button class="gyro-prompt" id="gyroPrompt" style="display:none;">Tap to enable tilt interaction</button>
    <div class="content">
        <div class="inner">
            <div class="avatar-wrapper">
                <img src="/photo.jpg" alt="Henri Kamarainen" class="avatar" width="96" height="96">
            </div>
            <div class="intro">
                <h1 class="name" data-scramble data-text={title}>{title}</h1>
                <p class="role" data-scramble data-text={tagline}>{tagline}</p>
            </div>
            <div class="divider"></div>
            <nav class="links">
                <a href="https://github.com/Henrixbor" target="_blank" rel="noopener" data-scramble data-text="GitHub">GitHub</a>
                <span class="dot">&#9679;</span>
                <a href="https://linkedin.com/in/kamarainen" target="_blank" rel="noopener" data-scramble data-text="LinkedIn">LinkedIn</a>
                <span class="dot">&#9679;</span>
                <a href="mailto:henkka.kamarainen@gmail.com" data-scramble data-text="Email">Email</a>
            </nav>
        </div>
    </div>

    <script>
    // ─── Shared pointer position (used by dot grid + scramble proximity) ──
    const pointer = { x: -1000, y: -1000 };
    const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

    // ─── Gyro Ball (mobile) ─────────────────────────────────────
    const gyroBall = {
        x: -1000, y: -1000,
        vx: 0, vy: 0,
        active: false,
        gravity: 0.8,
        friction: 0.975,
        bounce: 0.35,
        refBeta: null,      // neutral holding angle (captured on init)
        refGamma: null,
    };

    function updateGyroBall() {
        if (!gyroBall.active) return;

        const w = window.innerWidth;
        const h = window.innerHeight;

        gyroBall.vx *= gyroBall.friction;
        gyroBall.vy *= gyroBall.friction;
        gyroBall.x += gyroBall.vx;
        gyroBall.y += gyroBall.vy;

        // Bounce off walls
        if (gyroBall.x < 0) { gyroBall.x = 0; gyroBall.vx *= -gyroBall.bounce; }
        if (gyroBall.x > w) { gyroBall.x = w; gyroBall.vx *= -gyroBall.bounce; }
        if (gyroBall.y < 0) { gyroBall.y = 0; gyroBall.vy *= -gyroBall.bounce; }
        if (gyroBall.y > h) { gyroBall.y = h; gyroBall.vy *= -gyroBall.bounce; }

        pointer.x = gyroBall.x;
        pointer.y = gyroBall.y;
    }

    function handleOrientation(e) {
        if (!gyroBall.active) return;

        const beta = e.beta || 0;
        const gamma = e.gamma || 0;

        // Capture the user's natural holding angle as reference
        if (gyroBall.refBeta === null) {
            gyroBall.refBeta = beta;
            gyroBall.refGamma = gamma;
            return;
        }

        // Delta from neutral position — tilt relative to how you're holding it
        let dBeta = beta - gyroBall.refBeta;
        let dGamma = gamma - gyroBall.refGamma;

        // Clamp deltas
        const MAX_TILT = 30;
        dBeta = Math.max(-MAX_TILT, Math.min(MAX_TILT, dBeta));
        dGamma = Math.max(-MAX_TILT, Math.min(MAX_TILT, dGamma));

        // Map tilt delta to acceleration (gamma = X, beta = Y)
        gyroBall.vx += (dGamma / MAX_TILT) * gyroBall.gravity;
        gyroBall.vy += (dBeta / MAX_TILT) * gyroBall.gravity;
    }

    async function initGyro() {
        gyroBall.x = window.innerWidth / 2;
        gyroBall.y = window.innerHeight / 2;
        gyroBall.refBeta = null;  // will capture on first orientation event
        gyroBall.refGamma = null;
        gyroBall.active = true;

        window.addEventListener('deviceorientation', handleOrientation);
    }

    // Show gyro prompt on touch devices
    if (isTouchDevice) {
        const prompt = document.getElementById('gyroPrompt');
        const needsPermission = typeof DeviceOrientationEvent !== 'undefined'
            && typeof DeviceOrientationEvent.requestPermission === 'function';

        // Only show prompt if gyro might be available
        if (typeof DeviceOrientationEvent !== 'undefined') {
            prompt.style.display = '';

            prompt.addEventListener('click', async () => {
                if (needsPermission) {
                    try {
                        const result = await DeviceOrientationEvent.requestPermission();
                        if (result === 'granted') {
                            await initGyro();
                        }
                    } catch (err) {
                        // Permission denied or unavailable
                    }
                } else {
                    await initGyro();
                }
                prompt.classList.add('hidden');
            });
        }
    }

    // ─── Interactive Dot Grid ───────────────────────────────────
    (function() {
        const canvas = document.getElementById('dotGrid');
        const ctx = canvas.getContext('2d');

        const DOT_SPACING = 28;
        const DOT_RADIUS = 1.2;
        const INFLUENCE_RADIUS = 150;
        const MAX_DISPLACEMENT = 20;
        const SPRING = 0.06;
        const DAMPING = 0.82;
        const BASE_ALPHA = 0.2;
        const HOVER_ALPHA = 0.9;

        const BASE_R = 113, BASE_G = 113, BASE_B = 122;
        const HOVER_R = 167, HOVER_G = 139, HOVER_B = 250;

        const GLOW_DECAY = 0.99;  // ~2 second fade trail

        let dots = [];
        let w, h;

        function init() {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
            dots = [];

            const cols = Math.ceil(w / DOT_SPACING) + 2;
            const rows = Math.ceil(h / DOT_SPACING) + 2;
            const offsetX = (w - (cols - 1) * DOT_SPACING) / 2;
            const offsetY = (h - (rows - 1) * DOT_SPACING) / 2;

            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    dots.push({
                        ox: offsetX + c * DOT_SPACING,
                        oy: offsetY + r * DOT_SPACING,
                        x: offsetX + c * DOT_SPACING,
                        y: offsetY + r * DOT_SPACING,
                        vx: 0,
                        vy: 0,
                        glow: 0,  // persistent glow intensity (0-1)
                    });
                }
            }
        }

        function animate() {
            // Update gyro ball physics each frame
            updateGyroBall();

            ctx.clearRect(0, 0, w, h);

            for (let i = 0; i < dots.length; i++) {
                const d = dots[i];
                const dx = pointer.x - d.ox;
                const dy = pointer.y - d.oy;
                const dist = Math.sqrt(dx * dx + dy * dy);

                if (dist < INFLUENCE_RADIUS) {
                    const force = (1 - dist / INFLUENCE_RADIUS);
                    const forceSq = force * force;
                    const angle = Math.atan2(dy, dx);
                    const push = forceSq * MAX_DISPLACEMENT;
                    d.vx += (-Math.cos(angle) * push - (d.x - d.ox)) * SPRING;
                    d.vy += (-Math.sin(angle) * push - (d.y - d.oy)) * SPRING;
                } else {
                    d.vx += (d.ox - d.x) * SPRING;
                    d.vy += (d.oy - d.y) * SPRING;
                }

                d.vx *= DAMPING;
                d.vy *= DAMPING;
                d.x += d.vx;
                d.y += d.vy;

                const liveProximity = dist < INFLUENCE_RADIUS
                    ? Math.pow(1 - dist / INFLUENCE_RADIUS, 1.5)
                    : 0;

                // Update persistent glow: ramp up instantly, decay slowly
                if (liveProximity > d.glow) {
                    d.glow = liveProximity;
                } else {
                    d.glow *= GLOW_DECAY;
                    if (d.glow < 0.005) d.glow = 0;
                }

                // Use whichever is stronger: live proximity or lingering glow
                const proximity = Math.max(liveProximity, d.glow);

                const r = Math.round(BASE_R + (HOVER_R - BASE_R) * proximity);
                const g = Math.round(BASE_G + (HOVER_G - BASE_G) * proximity);
                const b = Math.round(BASE_B + (HOVER_B - BASE_B) * proximity);
                const alpha = BASE_ALPHA + (HOVER_ALPHA - BASE_ALPHA) * proximity;
                const radius = DOT_RADIUS + proximity * 1.2;

                ctx.beginPath();
                ctx.arc(d.x, d.y, radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
                ctx.fill();
            }

            requestAnimationFrame(animate);
        }

        // Desktop: mouse events
        window.addEventListener('mousemove', (e) => {
            pointer.x = e.clientX;
            pointer.y = e.clientY;
        });

        window.addEventListener('mouseleave', () => {
            pointer.x = -1000;
            pointer.y = -1000;
        });

        // Mobile: touch fallback (works alongside or without gyro)
        window.addEventListener('touchmove', (e) => {
            if (!gyroBall.active) {
                pointer.x = e.touches[0].clientX;
                pointer.y = e.touches[0].clientY;
            }
        }, { passive: true });

        window.addEventListener('touchend', () => {
            if (!gyroBall.active) {
                pointer.x = -1000;
                pointer.y = -1000;
            }
        });

        window.addEventListener('resize', init);
        init();
        animate();
    })();

    // ─── Text Scramble ──────────────────────────────────────────
    (function() {
        const GLYPHS = '!<>-_\\/[]{}—=+*^?#________';

        class Scramble {
            constructor(el) {
                this.el = el;
                this.originalText = el.dataset.text;
                this.queue = [];
                this.frame = 0;
                this.running = false;
                this.raf = null;
            }

            scrambleTo(text) {
                const current = this.el.textContent;
                const len = Math.max(current.length, text.length);
                this.queue = [];

                for (let i = 0; i < len; i++) {
                    const from = current[i] || '';
                    const to = text[i] || '';
                    const start = Math.floor(Math.random() * 15);
                    const end = start + Math.floor(Math.random() * 25) + 5;
                    this.queue.push({ from, to, start, end, char: null });
                }

                cancelAnimationFrame(this.raf);
                this.frame = 0;
                this.running = true;
                this.tick();
            }

            tick() {
                let output = '';
                let done = 0;

                for (let i = 0; i < this.queue.length; i++) {
                    const q = this.queue[i];

                    if (this.frame >= q.end) {
                        done++;
                        output += q.to;
                    } else if (this.frame >= q.start) {
                        if (!q.char || Math.random() < 0.3) {
                            q.char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                        }
                        output += `<span class="scramble-glyph">${q.char}</span>`;
                    } else {
                        output += q.from;
                    }
                }

                this.el.innerHTML = output;
                this.frame++;

                if (done < this.queue.length) {
                    this.raf = requestAnimationFrame(() => this.tick());
                } else {
                    this.running = false;
                }
            }

            reset() {
                cancelAnimationFrame(this.raf);
                this.running = false;
                this.el.textContent = this.originalText;
            }
        }

        const scramblers = [];

        document.querySelectorAll('[data-scramble]').forEach(el => {
            const s = new Scramble(el);
            scramblers.push(s);

            // Desktop: hover scramble
            el.addEventListener('mouseenter', () => {
                s.scrambleTo(s.originalText);
            });

            el.addEventListener('mouseleave', () => {
                if (!s.running) s.reset();
            });
        });

        // Entrance scramble on load (all devices)
        setTimeout(() => {
            scramblers.forEach((s, i) => {
                setTimeout(() => s.scrambleTo(s.originalText), i * 120);
            });
        }, 400);

        // Proximity-based scramble trigger for gyro ball / touch
        if (isTouchDevice) {
            let lastTriggered = new Map();

            function checkProximityScramble() {
                scramblers.forEach(s => {
                    const rect = s.el.getBoundingClientRect();
                    const cx = rect.left + rect.width / 2;
                    const cy = rect.top + rect.height / 2;
                    const dx = pointer.x - cx;
                    const dy = pointer.y - cy;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    const now = Date.now();
                    const last = lastTriggered.get(s) || 0;

                    if (dist < 100 && now - last > 1500) {
                        s.scrambleTo(s.originalText);
                        lastTriggered.set(s, now);
                    }
                });

                requestAnimationFrame(checkProximityScramble);
            }
            checkProximityScramble();
        }
    })();
    </script>
</body>
</html>
