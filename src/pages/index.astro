---
const title = "Henri Kamarainen";
const tagline = "Developer · Builder · AI Enthusiast";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={tagline}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #08080a;
            --text: #fafafa;
            --text-secondary: #a1a1aa;
            --text-tertiary: #52525b;
            --surface: #14141a;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            min-height: 100vh;
            overflow: hidden;
        }

        #dotGrid {
            position: fixed;
            inset: 0;
            z-index: 0;
        }

        .noise {
            position: fixed;
            inset: -50%;
            width: 200%;
            height: 200%;
            pointer-events: none;
            z-index: 1;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            animation: grain 8s steps(10) infinite;
        }

        @keyframes grain {
            0%, 100% { transform: translate(0, 0); }
            10% { transform: translate(-5%, -10%); }
            30% { transform: translate(3%, -15%); }
            50% { transform: translate(12%, 9%); }
            70% { transform: translate(9%, 4%); }
            90% { transform: translate(-1%, 7%); }
        }

        .content {
            position: fixed;
            inset: 0;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }

        .inner {
            text-align: center;
            padding: 2rem;
            pointer-events: auto;
        }

        .intro {
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .name {
            font-size: 2.2rem;
            font-weight: 500;
            letter-spacing: -0.04em;
            line-height: 1.1;
            color: var(--text);
        }

        .role {
            font-size: 0.9375rem;
            color: var(--text-secondary);
            margin-top: 0.75rem;
            font-weight: 300;
            letter-spacing: 0.02em;
        }

        .divider {
            width: 32px;
            height: 1px;
            background: #27272a;
            margin: 2rem auto;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
        }

        .links {
            display: flex;
            gap: 0.25rem;
            justify-content: center;
            animation: enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
        }

        .links a {
            color: var(--text-tertiary);
            text-decoration: none;
            font-size: 0.8125rem;
            font-weight: 400;
            letter-spacing: 0.01em;
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            transition: color 0.3s, background 0.3s;
            position: relative;
        }

        .links a:hover {
            color: var(--text);
            background: var(--surface);
        }

        .scramble-glyph {
            color: var(--text-tertiary);
            opacity: 0.5;
        }

        .dot {
            color: var(--text-tertiary);
            opacity: 0.3;
            align-self: center;
            font-size: 0.5rem;
        }

        @keyframes enter {
            from {
                opacity: 0;
                transform: translateY(16px);
                filter: blur(6px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
                filter: blur(0);
            }
        }

        @media (max-width: 768px) {
            .name { font-size: 1.6rem; }
            .inner { padding: 1.5rem; }
        }
    </style>
</head>
<body>
    <canvas id="dotGrid"></canvas>
    <div class="noise"></div>
    <div class="content">
        <div class="inner">
            <div class="intro">
                <h1 class="name" data-scramble data-text={title}>{title}</h1>
                <p class="role">{tagline}</p>
            </div>
            <div class="divider"></div>
            <nav class="links">
                <a href="https://github.com/Henrixbor" target="_blank" rel="noopener" data-scramble data-text="GitHub">GitHub</a>
                <span class="dot">&#9679;</span>
                <a href="https://linkedin.com/in/kamarainen" target="_blank" rel="noopener" data-scramble data-text="LinkedIn">LinkedIn</a>
                <span class="dot">&#9679;</span>
                <a href="mailto:henkka.kamarainen@gmail.com" data-scramble data-text="Email">Email</a>
            </nav>
        </div>
    </div>

    <script>
    // ─── Dot Grid + Hidden ASCII Portrait ───────────────────────
    (function() {
        const canvas = document.getElementById('dotGrid');
        const ctx = canvas.getContext('2d');

        // Dot grid config
        const SPACING = 14;
        const DOT_RADIUS = 0.8;
        const INFLUENCE_RADIUS = 100;
        const MAX_DISPLACEMENT = 14;
        const SPRING = 0.055;
        const DAMPING = 0.82;
        const BASE_ALPHA = 0.1;
        const HOVER_ALPHA = 0.35;
        const DOT_COLOR_R = 167, DOT_COLOR_G = 139, DOT_COLOR_B = 250;

        // ASCII portrait config
        const ASCII_CHARS = ' .:-=+*#%@';
        const AVATAR_URL = 'https://avatars.githubusercontent.com/u/40909974?s=200&v=4';
        const PORTRAIT_SIZE = 48; // grid cells for the portrait
        const REVEAL_RADIUS = 130;
        const REVEAL_EASE = 2.5; // power curve for sharper edge

        let dots = [];
        let mouse = { x: -1000, y: -1000 };
        let w, h;
        let portraitData = null; // luminance grid
        let portraitOriginX = 0, portraitOriginY = 0;

        // Load avatar and sample luminance
        function loadAvatar() {
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.onload = () => {
                const size = PORTRAIT_SIZE;
                const offscreen = document.createElement('canvas');
                offscreen.width = size;
                offscreen.height = size;
                const octx = offscreen.getContext('2d');
                octx.drawImage(img, 0, 0, size, size);
                const imageData = octx.getImageData(0, 0, size, size);
                const pixels = imageData.data;

                portraitData = [];
                for (let y = 0; y < size; y++) {
                    const row = [];
                    for (let x = 0; x < size; x++) {
                        const i = (y * size + x) * 4;
                        const r = pixels[i], g = pixels[i+1], b = pixels[i+2], a = pixels[i+3];
                        // Luminance (perceived brightness)
                        const lum = (0.299 * r + 0.587 * g + 0.114 * b) * (a / 255);
                        row.push(lum);
                    }
                    portraitData.push(row);
                }

                // Recalculate dot assignments
                assignPortrait();
            };
            img.src = AVATAR_URL;
        }

        function assignPortrait() {
            if (!portraitData || dots.length === 0) return;

            // Position portrait on the right side, vertically centered
            const gridW = Math.ceil(w / SPACING) + 2;
            const gridH = Math.ceil(h / SPACING) + 2;

            // Portrait top-left in grid coordinates
            const pGridCol = gridW - PORTRAIT_SIZE - 4;
            const pGridRow = Math.floor((gridH - PORTRAIT_SIZE) / 2);

            const offsetX = (w - (gridW - 1) * SPACING) / 2;
            const offsetY = (h - (gridH - 1) * SPACING) / 2;

            portraitOriginX = offsetX + pGridCol * SPACING + (PORTRAIT_SIZE * SPACING) / 2;
            portraitOriginY = offsetY + pGridRow * SPACING + (PORTRAIT_SIZE * SPACING) / 2;

            dots.forEach(d => {
                d.ascii = null;
                d.asciiAlpha = 0;
                d.isPortrait = false;
            });

            // Map dots to portrait pixels
            for (let py = 0; py < PORTRAIT_SIZE; py++) {
                for (let px = 0; px < PORTRAIT_SIZE; px++) {
                    const col = pGridCol + px;
                    const row = pGridRow + py;
                    if (col < 0 || row < 0 || col >= gridW || row >= gridH) continue;
                    const idx = row * gridW + col;
                    if (idx >= dots.length) continue;

                    const lum = portraitData[py][px];
                    const charIdx = Math.floor((lum / 255) * (ASCII_CHARS.length - 1));
                    dots[idx].ascii = ASCII_CHARS[charIdx];
                    dots[idx].isPortrait = true;
                    dots[idx].portraitLum = lum;
                }
            }
        }

        function init() {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
            dots = [];

            const cols = Math.ceil(w / SPACING) + 2;
            const rows = Math.ceil(h / SPACING) + 2;
            const offsetX = (w - (cols - 1) * SPACING) / 2;
            const offsetY = (h - (rows - 1) * SPACING) / 2;

            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    dots.push({
                        ox: offsetX + c * SPACING,
                        oy: offsetY + r * SPACING,
                        x: offsetX + c * SPACING,
                        y: offsetY + r * SPACING,
                        vx: 0,
                        vy: 0,
                        ascii: null,
                        asciiAlpha: 0,
                        isPortrait: false,
                        portraitLum: 0,
                    });
                }
            }

            assignPortrait();
        }

        function animate() {
            ctx.clearRect(0, 0, w, h);
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.font = `${SPACING - 2}px "Courier New", monospace`;

            for (let i = 0; i < dots.length; i++) {
                const d = dots[i];
                const dx = mouse.x - d.ox;
                const dy = mouse.y - d.oy;
                const dist = Math.sqrt(dx * dx + dy * dy);

                // Spring physics (only for non-portrait dots, or portrait dots not being revealed)
                if (!d.isPortrait) {
                    if (dist < INFLUENCE_RADIUS) {
                        const force = (1 - dist / INFLUENCE_RADIUS);
                        const forceSq = force * force;
                        const angle = Math.atan2(dy, dx);
                        const push = forceSq * MAX_DISPLACEMENT;
                        d.vx += (-Math.cos(angle) * push - (d.x - d.ox)) * SPRING;
                        d.vy += (-Math.sin(angle) * push - (d.y - d.oy)) * SPRING;
                    } else {
                        d.vx += (d.ox - d.x) * SPRING;
                        d.vy += (d.oy - d.y) * SPRING;
                    }
                    d.vx *= DAMPING;
                    d.vy *= DAMPING;
                    d.x += d.vx;
                    d.y += d.vy;
                }

                if (d.isPortrait) {
                    // Calculate reveal amount based on cursor distance to this dot
                    const revealDist = Math.sqrt(
                        (mouse.x - d.ox) ** 2 + (mouse.y - d.oy) ** 2
                    );
                    const targetAlpha = revealDist < REVEAL_RADIUS
                        ? Math.pow(1 - revealDist / REVEAL_RADIUS, REVEAL_EASE)
                        : 0;

                    // Smooth interpolation
                    d.asciiAlpha += (targetAlpha - d.asciiAlpha) * 0.12;

                    if (d.asciiAlpha > 0.005) {
                        // Draw ASCII character
                        const lumNorm = d.portraitLum / 255;
                        const alpha = d.asciiAlpha * (0.15 + lumNorm * 0.65);
                        ctx.fillStyle = `rgba(${DOT_COLOR_R}, ${DOT_COLOR_G}, ${DOT_COLOR_B}, ${alpha})`;
                        ctx.fillText(d.ascii, d.ox, d.oy);
                    }

                    // Draw the covering dot (fades out as ASCII fades in)
                    const dotAlpha = BASE_ALPHA * (1 - d.asciiAlpha * 0.9);
                    if (dotAlpha > 0.005) {
                        ctx.beginPath();
                        ctx.arc(d.ox, d.oy, DOT_RADIUS, 0, Math.PI * 2);
                        ctx.fillStyle = `rgba(${DOT_COLOR_R}, ${DOT_COLOR_G}, ${DOT_COLOR_B}, ${dotAlpha})`;
                        ctx.fill();
                    }
                } else {
                    // Regular dot
                    const displacement = Math.sqrt((d.x - d.ox) ** 2 + (d.y - d.oy) ** 2);
                    const alpha = BASE_ALPHA + (HOVER_ALPHA - BASE_ALPHA) * Math.min(displacement / MAX_DISPLACEMENT, 1);
                    const radius = DOT_RADIUS + displacement * 0.04;

                    ctx.beginPath();
                    ctx.arc(d.x, d.y, radius, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(${DOT_COLOR_R}, ${DOT_COLOR_G}, ${DOT_COLOR_B}, ${alpha})`;
                    ctx.fill();
                }
            }

            requestAnimationFrame(animate);
        }

        window.addEventListener('mousemove', (e) => {
            mouse.x = e.clientX;
            mouse.y = e.clientY;
        });

        window.addEventListener('mouseleave', () => {
            mouse.x = -1000;
            mouse.y = -1000;
        });

        window.addEventListener('resize', init);
        init();
        loadAvatar();
        animate();
    })();

    // ─── Text Scramble ──────────────────────────────────────────
    (function() {
        const GLYPHS = '!<>-_\\/[]{}—=+*^?#________';

        class Scramble {
            constructor(el) {
                this.el = el;
                this.originalText = el.dataset.text;
                this.queue = [];
                this.frame = 0;
                this.running = false;
                this.raf = null;
            }

            scrambleTo(text) {
                const current = this.el.textContent;
                const len = Math.max(current.length, text.length);
                this.queue = [];

                for (let i = 0; i < len; i++) {
                    const from = current[i] || '';
                    const to = text[i] || '';
                    const start = Math.floor(Math.random() * 15);
                    const end = start + Math.floor(Math.random() * 25) + 5;
                    this.queue.push({ from, to, start, end, char: null });
                }

                cancelAnimationFrame(this.raf);
                this.frame = 0;
                this.running = true;
                this.tick();
            }

            tick() {
                let output = '';
                let done = 0;

                for (let i = 0; i < this.queue.length; i++) {
                    const q = this.queue[i];

                    if (this.frame >= q.end) {
                        done++;
                        output += q.to;
                    } else if (this.frame >= q.start) {
                        if (!q.char || Math.random() < 0.3) {
                            q.char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                        }
                        output += `<span class="scramble-glyph">${q.char}</span>`;
                    } else {
                        output += q.from;
                    }
                }

                this.el.innerHTML = output;
                this.frame++;

                if (done < this.queue.length) {
                    this.raf = requestAnimationFrame(() => this.tick());
                } else {
                    this.running = false;
                }
            }

            reset() {
                cancelAnimationFrame(this.raf);
                this.running = false;
                this.el.textContent = this.originalText;
            }
        }

        document.querySelectorAll('[data-scramble]').forEach(el => {
            const s = new Scramble(el);

            el.addEventListener('mouseenter', () => {
                s.scrambleTo(s.originalText);
            });

            el.addEventListener('mouseleave', () => {
                if (!s.running) {
                    s.reset();
                }
            });
        });
    })();
    </script>
</body>
</html>
