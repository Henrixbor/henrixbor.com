---
const title = "Henri Kamarainen";
const tagline = "Developer · Builder · AI Enthusiast";

const projects = [
    {
        title: "OpenClaw",
        description: "Open-source AI assistant framework for building autonomous agents with tool use, memory, and multi-channel support.",
        tech: ["TypeScript", "Node.js", "AI/ML", "Framework"],
        github: "https://github.com/openclaw/openclaw",
        website: "https://openclaw.ai",
        icon: "🦞"
    },
    {
        title: "Moltbook",
        description: "Social platform built for AI agents to share, discuss, and collaborate. The social network where AIs are first-class citizens.",
        tech: ["Web Platform", "AI Agents", "Social"],
        github: null,
        website: "https://moltbook.com",
        icon: "🦀"
    },
    {
        title: "Clawd AI Assistant",
        description: "Autonomous AI assistant automating workflows, managing infrastructure, and learning continuously via OpenClaw.",
        tech: ["Python", "OpenClaw", "Automation"],
        github: "https://github.com/openclawbob/clawd",
        website: null,
        icon: "🤖"
    },
    {
        title: "Portfolio Website",
        description: "This site — a modern, performant portfolio built with Astro and deployed globally on Cloudflare Pages.",
        tech: ["Astro", "TypeScript", "Cloudflare"],
        github: "https://github.com/openclawbob/henrixbor.com",
        website: "https://henrixbor.com",
        icon: "🌐"
    },
    {
        title: "Railway Infrastructure",
        description: "Infrastructure automation for deploying applications with PostgreSQL, Redis, caching layers, and cron workers.",
        tech: ["Railway", "Docker", "PostgreSQL", "Redis"],
        github: null,
        website: null,
        icon: "🚂"
    },
    {
        title: "Security Automation",
        description: "Comprehensive security auditing and monitoring tools for infrastructure hardening and vulnerability detection.",
        tech: ["Bash", "Python", "Security"],
        github: null,
        website: null,
        icon: "🔒"
    }
];

const skills = [
    "Python", "TypeScript", "JavaScript", "Node.js", "Rust",
    "AI / ML", "LLMs", "Automation", "Docker", "Git",
    "Linux", "PostgreSQL", "Redis", "Cloudflare",
    "Railway", "Astro", "React", "REST APIs", "CI/CD", "Security"
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={tagline}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #0a0a0b;
            --bg-card: #111113;
            --bg-card-hover: #18181b;
            --border: #1e1e22;
            --border-hover: #2a2a30;
            --text: #e4e4e7;
            --text-muted: #71717a;
            --text-dim: #52525b;
            --accent: #8b5cf6;
            --accent-dim: rgba(139, 92, 246, 0.12);
            --gradient: linear-gradient(135deg, #8b5cf6, #6366f1, #3b82f6);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

        /* Noise overlay */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
        }

        /* Glow blob */
        .glow {
            position: fixed;
            top: -200px;
            left: 50%;
            transform: translateX(-50%);
            width: 800px;
            height: 500px;
            background: radial-gradient(ellipse, rgba(139,92,246,0.08) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        main { position: relative; z-index: 1; }

        /* ── Header ── */
        header {
            padding: 6rem 0 4rem;
            text-align: center;
        }

        header h1 {
            font-size: 3.2rem;
            font-weight: 700;
            letter-spacing: -0.03em;
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: fadeUp 0.6s ease both;
        }

        header .tagline {
            font-size: 1.15rem;
            color: var(--text-muted);
            margin-top: 0.75rem;
            font-weight: 400;
            animation: fadeUp 0.6s ease 0.1s both;
        }

        .social-links {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-top: 2rem;
            animation: fadeUp 0.6s ease 0.2s both;
        }

        .social-link {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 1.2rem;
            color: var(--text-muted);
            text-decoration: none;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .social-link:hover {
            color: var(--text);
            border-color: var(--border-hover);
            background: var(--bg-card);
        }

        .social-link svg { width: 18px; height: 18px; }

        /* ── Section ── */
        section { margin-bottom: 5rem; }

        .section-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--accent);
            margin-bottom: 2rem;
            animation: fadeUp 0.6s ease both;
        }

        /* ── Project Grid ── */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

        .project-card {
            background: var(--bg-card);
            padding: 2rem;
            display: flex;
            flex-direction: column;
            transition: background 0.2s;
            animation: fadeUp 0.5s ease both;
        }

        .project-card:hover { background: var(--bg-card-hover); }

        .card-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .project-icon { font-size: 2rem; line-height: 1; }

        .card-links {
            display: flex;
            gap: 0.5rem;
        }

        .card-link {
            color: var(--text-dim);
            padding: 0.35rem;
            border-radius: 6px;
            transition: all 0.2s;
            display: flex;
        }

        .card-link:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .card-link svg { width: 18px; height: 18px; }

        .project-title {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 0.5rem;
        }

        .project-description {
            font-size: 0.875rem;
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 1.25rem;
            flex: 1;
        }

        .tech-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
        }

        .tech-tag {
            font-size: 0.7rem;
            font-weight: 500;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            background: var(--accent-dim);
            color: var(--accent);
        }

        /* ── Skills ── */
        .skills-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .skill-badge {
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.45rem 1rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text-muted);
            transition: all 0.2s;
            animation: fadeUp 0.5s ease both;
        }

        .skill-badge:hover {
            color: var(--text);
            border-color: var(--border-hover);
            background: var(--bg-card);
        }

        /* ── Footer ── */
        footer {
            padding: 3rem 0;
            text-align: center;
            border-top: 1px solid var(--border);
            color: var(--text-dim);
            font-size: 0.8rem;
        }

        footer span { color: var(--accent); }

        /* ── Animations ── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .project-card:nth-child(1) { animation-delay: 0s; }
        .project-card:nth-child(2) { animation-delay: 0.05s; }
        .project-card:nth-child(3) { animation-delay: 0.1s; }
        .project-card:nth-child(4) { animation-delay: 0.15s; }
        .project-card:nth-child(5) { animation-delay: 0.2s; }
        .project-card:nth-child(6) { animation-delay: 0.25s; }

        .skill-badge:nth-child(even) { animation-delay: 0.05s; }

        /* ── Responsive ── */
        @media (max-width: 700px) {
            header { padding: 4rem 0 3rem; }
            header h1 { font-size: 2.2rem; }
            .projects-grid { grid-template-columns: 1fr; }
            .container { padding: 0 1.25rem; }
        }
    </style>
</head>
<body>
    <div class="glow"></div>
    <main>
        <header>
            <div class="container">
                <h1>{title}</h1>
                <p class="tagline">{tagline}</p>
                <div class="social-links">
                    <a href="https://github.com/openclawbob" class="social-link" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                        GitHub
                    </a>
                    <a href="mailto:henkka.kamarainen@gmail.com" class="social-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        Email
                    </a>
                </div>
            </div>
        </header>

        <section class="container">
            <p class="section-label">Projects</p>
            <div class="projects-grid">
                {projects.map(project => (
                    <div class="project-card">
                        <div class="card-top">
                            <span class="project-icon">{project.icon}</span>
                            <div class="card-links">
                                {project.github && (
                                    <a href={project.github} class="card-link" target="_blank" rel="noopener" title="Source code">
                                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                                    </a>
                                )}
                                {project.website && (
                                    <a href={project.website} class="card-link" target="_blank" rel="noopener" title="Live site">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                    </a>
                                )}
                            </div>
                        </div>
                        <h3 class="project-title">{project.title}</h3>
                        <p class="project-description">{project.description}</p>
                        <div class="tech-tags">
                            {project.tech.map(t => (
                                <span class="tech-tag">{t}</span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section class="container">
            <p class="section-label">Technologies</p>
            <div class="skills-grid">
                {skills.map(skill => (
                    <span class="skill-badge">{skill}</span>
                ))}
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p>© 2026 Henri Kamarainen · Built with <span>Astro</span></p>
        </div>
    </footer>
</body>
</html>
