                    else if (pct === 100 && battVal.includes('charging')) deds.push({ icon: '\u{26A1}', text: 'Fully charged and plugged in — stationary setup', confidence: 95 });
                    else if (battVal.includes('charging')) deds.push({ icon: '\u{26A1}', text: `Charging at ${pct}% — device is plugged in`, confidence: 99 });
                    else if (pct > 90) deds.push({ icon: '\u{1F50B}', text: `Battery healthy at ${pct}% — freshly unplugged`, confidence: 70 });
