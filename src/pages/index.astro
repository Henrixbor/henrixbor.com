            const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
            info.connection = { label: 'Connection', value: conn ? `${conn.effectiveType || '?'} / ${conn.downlink || '?'} Mbps` : 'Unknown' };
            info.battery = { label: 'Battery', value: '...' };

            // Preferences
            const prefs = [
                window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark mode' : 'light mode',
                window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'reduced motion' : null,
                window.matchMedia('(prefers-contrast: more)').matches ? 'high contrast' : null,
