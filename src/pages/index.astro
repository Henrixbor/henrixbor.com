            }
            if (fontVal.includes('Futura') || fontVal.includes('Helvetica')) {
                if (!devSignals.isDev) deds.push({ icon: '\u{1F3A8}', text: 'Design fonts detected — creative background?', confidence: 55 });
            }

            // ── Media devices ──
            const mediaVal = info.mediaDevices?.value || '';
            const camMatch = mediaVal.match(/(\d+) cam/);
            const micMatch = mediaVal.match(/(\d+) mic/);
            if (camMatch && parseInt(camMatch[1]) > 1) {
                deds.push({ icon: '\u{1F4F7}', text: `${camMatch[1]} cameras detected — external webcam or streaming setup`, confidence: 75 });
            }
            if (micMatch && parseInt(micMatch[1]) > 2) {
                deds.push({ icon: '\u{1F3A4}', text: `${micMatch[1]} microphones — podcaster, musician, or meeting junkie?`, confidence: 65 });
            }

            // ── Gamepad ──
            if (info.gamepad?.value && info.gamepad.value !== 'None' && info.gamepad.value !== 'Not supported') {
                deds.push({ icon: '\u{1F3AE}', text: `Game controller connected (${info.gamepad.value.substring(0, 40)})`, confidence: 95 });
            }

            // ── Session behavior ──
            const sessionSec = parseFloat(info.sessionTime?.value) || 0;
