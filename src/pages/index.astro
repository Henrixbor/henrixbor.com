            // ── Window size vs screen ──
            const windowRatio = (window.innerWidth * window.innerHeight) / (w * h * dpr * dpr);
            if (!isMobile && windowRatio < 0.4) {
                deds.push({ icon: '\u{1F5BC}', text: 'Browser window is small — split-screening or multitasking', confidence: 85 });
