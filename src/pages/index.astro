            } else if (ref === 'Direct visit') {
                deds.push({ icon: '\u{1F3AF}', text: 'Direct visit — typed the URL or bookmarked', confidence: 80 });
            }

            // ── Storage usage insight ──
            const storageVal = info.storage?.value || '';
            const usedMatch = storageVal.match(/([\d.]+) MB used/);
            if (usedMatch) {
                const usedMB = parseFloat(usedMatch[1]);
                if (usedMB > 500) deds.push({ icon: '\u{1F4E6}', text: `${Math.round(usedMB)} MB of browser storage used — heavy web app user`, confidence: 75 });
            }

            // ── Service workers ──
            const swVal = info.sw?.value || '';
            const swMatch = swVal.match(/(\d+) registered/);
            if (swMatch && parseInt(swMatch[1]) > 3) {
                deds.push({ icon: '\u{2699}', text: `${swMatch[1]} service workers — lots of web apps installed`, confidence: 80 });
            }

            return deds;
        }

        // ── Device identification database ──
        function identifyDevice(w, h, dpr, gpu, ua, touch) {
            const sw = Math.min(w, h), sh = Math.max(w, h);
            const gpuLow = gpu.toLowerCase();

            // iPhones
            if (ua.includes('iPhone')) {
                if (sw === 393 && sh === 852) return { name: 'iPhone 15 / 15 Pro', confidence: 90 };
                if (sw === 430 && sh === 932) return { name: 'iPhone 15 Plus / 15 Pro Max', confidence: 90 };
                if (sw === 390 && sh === 844) return { name: 'iPhone 13 / 14', confidence: 85 };
                if (sw === 428 && sh === 926) return { name: 'iPhone 13/14 Pro Max', confidence: 85 };
                if (sw === 375 && sh === 812) return { name: 'iPhone X / 11 Pro / 12 Mini', confidence: 75 };
                if (sw === 414 && sh === 896) return { name: 'iPhone 11 / XR / 11 Pro Max', confidence: 75 };
                return { name: 'iPhone (model unclear)', confidence: 60 };
            }
            // iPads
            if (ua.includes('iPad') || (ua.includes('Macintosh') && touch > 0)) {
                if (sw === 1024 && sh === 1366) return { name: 'iPad Pro 12.9"', confidence: 85 };
                if (sw === 834 && sh === 1194) return { name: 'iPad Pro 11"', confidence: 85 };
                if (sw === 820 && sh === 1180) return { name: 'iPad Air', confidence: 80 };
                if (sw === 810 && sh === 1080) return { name: 'iPad 10th gen', confidence: 80 };
                return { name: 'iPad', confidence: 65 };
            }
            // Macs
            if (ua.includes('Macintosh') && touch === 0) {
                if (gpuLow.includes('m1') || gpuLow.includes('m2') || gpuLow.includes('m3') || gpuLow.includes('m4') || gpuLow.includes('apple')) {
                    if (sh >= 1800 && dpr >= 2) return { name: 'MacBook Pro 16" (Apple Silicon)', confidence: 80 };
                    if (sh >= 1600 && dpr >= 2) return { name: 'MacBook Pro 14" (Apple Silicon)', confidence: 75 };
                    if (sh <= 900 && dpr >= 2) return { name: 'MacBook Air 13" (Apple Silicon)', confidence: 75 };
                    return { name: 'Mac (Apple Silicon)', confidence: 70 };
                }
                if (gpuLow.includes('intel')) return { name: 'Mac (Intel)', confidence: 65 };
                return { name: 'Mac', confidence: 55 };
            }
            // Android
            if (ua.includes('Android')) {
                if (gpuLow.includes('adreno 7')) return { name: 'Android flagship (Snapdragon 8)', confidence: 70 };
                if (gpuLow.includes('adreno 6')) return { name: 'Android mid-range (Snapdragon 7/6)', confidence: 65 };
                if (gpuLow.includes('mali-g7')) return { name: 'Android flagship (Exynos/Dimensity)', confidence: 65 };
                return { name: 'Android device', confidence: 50 };
            }
            // Windows
            if (ua.includes('Windows')) {
                if (gpuLow.includes('rtx 40')) return { name: 'Windows PC (RTX 40-series GPU)', confidence: 80 };
                if (gpuLow.includes('rtx 30')) return { name: 'Windows PC (RTX 30-series GPU)', confidence: 80 };
                if (gpuLow.includes('rtx')) return { name: 'Windows PC (RTX GPU)', confidence: 75 };
                if (gpuLow.includes('gtx')) return { name: 'Windows PC (GTX GPU)', confidence: 75 };
                if (gpuLow.includes('radeon')) return { name: 'Windows PC (AMD GPU)', confidence: 70 };
                if (gpuLow.includes('intel') && gpuLow.includes('iris')) return { name: 'Windows laptop (Intel Iris)', confidence: 70 };
                if (gpuLow.includes('intel')) return { name: 'Windows PC (Intel graphics)', confidence: 60 };
                return { name: 'Windows PC', confidence: 50 };
            }
            if (ua.includes('Linux')) return { name: 'Linux machine', confidence: 55 };
            return null;
        }

        // ── Device tier estimation ──
        function estimateDeviceTier(cores, mem, dpr, gpu, w, h) {
            let score = 0;
            const gpuLow = gpu.toLowerCase();
            if (cores >= 16) score += 30; else if (cores >= 8) score += 20; else if (cores >= 4) score += 10;
            if (mem >= 8) score += 25; else if (mem >= 4) score += 15; else if (mem > 0) score += 5;
            if (dpr >= 3) score += 15; else if (dpr >= 2) score += 10;
            if (gpuLow.includes('rtx 40') || gpuLow.includes('m3') || gpuLow.includes('m4')) score += 25;
            else if (gpuLow.includes('rtx 30') || gpuLow.includes('m2') || gpuLow.includes('apple')) score += 20;
            else if (gpuLow.includes('rtx') || gpuLow.includes('m1')) score += 15;
            if (Math.max(w, h) >= 2560) score += 5;

            if (score >= 60) return { label: 'Flagship / high-end ($1,500+)', confidence: 70 };
            if (score >= 40) return { label: 'Upper mid-range ($800\u{2013}1,500)', confidence: 65 };
            if (score >= 20) return { label: 'Mid-range ($400\u{2013}800)', confidence: 60 };
            return { label: 'Budget / entry-level (<$400)', confidence: 55 };
        }

        // ── VPN detection via timezone mismatch ──
        function detectVPN(tz, locationStr) {
            const tzCountryMap = {
                'America/New_York': 'United States', 'America/Chicago': 'United States',
                'America/Denver': 'United States', 'America/Los_Angeles': 'United States',
                'Europe/London': 'United Kingdom', 'Europe/Paris': 'France',
                'Europe/Berlin': 'Germany', 'Europe/Helsinki': 'Finland',
                'Europe/Stockholm': 'Sweden', 'Europe/Oslo': 'Norway',
                'Europe/Copenhagen': 'Denmark', 'Europe/Amsterdam': 'Netherlands',
                'Asia/Tokyo': 'Japan', 'Asia/Shanghai': 'China',
                'Asia/Kolkata': 'India', 'Australia/Sydney': 'Australia',
                'America/Toronto': 'Canada', 'America/Sao_Paulo': 'Brazil',
            };
            const expectedCountry = tzCountryMap[tz];
            if (!expectedCountry) return { detected: false };
            const locLower = locationStr.toLowerCase();
            if (!locLower.includes(expectedCountry.toLowerCase())) {
                return { detected: true, confidence: 75 };
            }
            return { detected: false };
        }

        // ── Incognito detection ──
        function detectIncognito() {
            try {
                // Safari: reduced storage in private mode
                if (window.safari) {
                    try { localStorage.setItem('_t', '1'); localStorage.removeItem('_t'); }
                    catch { return true; }
                }
                // Firefox: indexedDB unavailable in private
                if (navigator.userAgent.includes('Firefox')) {
                    try {
                        const db = indexedDB.open('_t');
                        db.onerror = () => true;
                    } catch { return true; }
                }
                // Chrome: reduced storage quota in incognito
                if (navigator.storage && navigator.storage.estimate) {
                    // Can't await here synchronously, so skip for now
                }
            } catch {}
            return false;
        }

        // ── Ad blocker detection ──
        function detectAdBlocker() {
            const el = document.createElement('div');
            el.className = 'ad ads adsbox ad-placement doubleclick';
            el.style.cssText = 'position:absolute;left:-9999px;width:1px;height:1px;';
            document.body.appendChild(el);
            const blocked = el.offsetHeight === 0 || el.offsetWidth === 0 || getComputedStyle(el).display === 'none';
            document.body.removeChild(el);
            return blocked;
        }

        // ── Developer detection ──
        function detectDeveloper(ua, gpu) {
            const reasons = [];
            // DevTools size heuristic (viewport vs window outer)
            if (window.outerWidth - window.innerWidth > 160 || window.outerHeight - window.innerHeight > 200) {
                reasons.push('DevTools likely open');
            }
            // macOS + many CPU cores + dev browser
            if (ua.includes('Macintosh') && navigator.hardwareConcurrency >= 8) {
                if (ua.includes('Chrome') || ua.includes('Firefox')) reasons.push('power setup');
            }
            // Linux desktop user
            if (ua.includes('Linux') && !ua.includes('Android')) reasons.push('Linux desktop');
            // High core count
            if (navigator.hardwareConcurrency >= 12) reasons.push('high-core CPU');

            if (reasons.length > 0) {
                return { isDev: true, reason: reasons.join(', '), confidence: Math.min(85, 50 + reasons.length * 15) };
            }
            return { isDev: false };
        }

        // ── Bot detection ──
        function detectBot(ua) {
            if (navigator.webdriver) return { isBot: true, reason: 'webdriver flag', confidence: 95 };
            if (!window.chrome && ua.includes('Chrome')) return { isBot: true, reason: 'headless Chrome', confidence: 80 };
            if (ua.includes('HeadlessChrome')) return { isBot: true, reason: 'HeadlessChrome', confidence: 99 };
            if (ua.includes('PhantomJS')) return { isBot: true, reason: 'PhantomJS', confidence: 99 };
            if (ua.includes('bot') || ua.includes('crawler') || ua.includes('spider')) return { isBot: true, reason: 'bot UA', confidence: 90 };
            return { isBot: false };
        }

        // ── Browsing context inference ──
        function inferContext(hour, connStr, touch) {
            const isWifi = connStr.includes('4g') && !connStr.includes('0.') || connStr.includes('Mbps');
            if (touch > 0) {
                if (hour >= 22 || hour < 6) return { icon: '\u{1F6CF}', where: 'bed', confidence: 70 };
                if (hour >= 7 && hour < 9) return { icon: '\u{1F687}', where: 'commute', confidence: 55 };
                if (hour >= 17 && hour < 19) return { icon: '\u{1F687}', where: 'commute', confidence: 50 };
                return { icon: '\u{1F4F1}', where: 'mobile', confidence: 60 };
            }
            if (hour >= 9 && hour < 17) return { icon: '\u{1F3E2}', where: 'work', confidence: 60 };
            return { icon: '\u{1F3E0}', where: 'home', confidence: 55 };
        }

        function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

        function detectBrowser(ua) {
            if (ua.includes('Firefox/')) return 'Firefox ' + ua.split('Firefox/')[1].split(' ')[0];
            if (ua.includes('Edg/')) return 'Edge ' + ua.split('Edg/')[1].split(' ')[0];
            if (ua.includes('OPR/')) return 'Opera ' + ua.split('OPR/')[1].split(' ')[0];
            if (ua.includes('Chrome/')) return 'Chrome ' + ua.split('Chrome/')[1].split(' ')[0];
            if (ua.includes('Safari/') && ua.includes('Version/')) return 'Safari ' + ua.split('Version/')[1].split(' ')[0];
            return ua.substring(0, 50);
        }

        function detectEngine(ua) {
            if (ua.includes('Gecko/') && ua.includes('Firefox')) return 'Gecko';
            if (ua.includes('AppleWebKit/')) return 'WebKit';
            return 'Unknown';
        }

        function detectOS(ua) {
            if (ua.includes('Mac OS X')) {
                const v = ua.match(/Mac OS X (\d+[_.\d]+)/);
                return 'macOS ' + (v ? v[1].replace(/_/g, '.') : '');
            }
            if (ua.includes('Windows NT')) {
                const v = ua.match(/Windows NT (\d+\.\d+)/);
                const map = { '10.0': '10/11', '6.3': '8.1', '6.2': '8', '6.1': '7' };
                return 'Windows ' + (v ? (map[v[1]] || v[1]) : '');
            }
            if (ua.includes('Android')) return 'Android ' + (ua.match(/Android (\d+[.\d]*)/) || ['',''])[1];
            if (ua.includes('iPhone') || ua.includes('iPad')) return 'iOS ' + (ua.match(/OS (\d+[_\d]*)/) || ['',''])[1].replace(/_/g, '.');
            if (ua.includes('Linux')) return 'Linux';
            return 'Unknown';
        }

        function getGPU() {
            try {
                const c = document.createElement('canvas');
                const gl = c.getContext('webgl') || c.getContext('experimental-webgl');
                if (!gl) return 'No WebGL';
                const ext = gl.getExtension('WEBGL_debug_renderer_info');
                if (!ext) return 'WebGL (renderer hidden)';
                return gl.getParameter(ext.UNMASKED_RENDERER_WEBGL);
            } catch { return 'Unknown'; }
        }

        function getCanvasFingerprint() {
            try {
                const c = document.createElement('canvas');
                c.width = 200; c.height = 50;
                const ctx = c.getContext('2d');
                ctx.textBaseline = 'top';
                ctx.font = '14px Arial';
                ctx.fillStyle = '#f60';
                ctx.fillRect(50, 5, 100, 20);
                ctx.fillStyle = '#069';
                ctx.fillText('fingerprint', 2, 15);
                ctx.fillStyle = 'rgba(102, 204, 0, 0.7)';
                ctx.fillText('fingerprint', 4, 17);
                const data = c.toDataURL();
                // Simple hash
                let hash = 0;
                for (let i = 0; i < data.length; i++) {
                    hash = ((hash << 5) - hash) + data.charCodeAt(i);
                    hash |= 0;
                }
                return (hash >>> 0).toString(16).padStart(8, '0');
            } catch { return 'blocked'; }
        }

        // ── Map initialization ──
        let modalMapInstance = null;
        let mapAnimFrame = null;
        function initModalMap(lat, lon) {
            const mapEl = document.getElementById('modalMap');
            const gpsDot = document.getElementById('mapGpsDot');
            if (!mapEl || !window.L) return;

            // Clean up previous instance
            if (modalMapInstance) {
                modalMapInstance.remove();
                modalMapInstance = null;
            }
            if (mapAnimFrame) { cancelAnimationFrame(mapAnimFrame); mapAnimFrame = null; }

            const hasCoords = lat != null && lon != null && isFinite(lat) && isFinite(lon);
            console.log('[map] hasCoords:', hasCoords, 'lat:', lat, 'lon:', lon);
            const startLat = hasCoords ? lat : 30;
            const startLon = hasCoords ? lon : 0;

            // Reset map container
            mapEl.innerHTML = '';
            mapEl.classList.remove('visible');
            if (gpsDot) gpsDot.classList.remove('visible');
            // Ensure explicit dimensions (Leaflet needs non-zero size)
            const modal = mapEl.closest('.modal');
            if (modal) {
                const rect = modal.getBoundingClientRect();
                mapEl.style.width = rect.width + 'px';
                mapEl.style.height = rect.height + 'px';
            }

            const map = L.map(mapEl, {
                zoomControl: false,
                attributionControl: false,
                dragging: false,
                scrollWheelZoom: false,
                doubleClickZoom: false,
                touchZoom: false,
                keyboard: false,
                boxZoom: false,
            }).setView([startLat, startLon], 3);

            // CartoDB Dark Matter WITH labels (roads, borders, city names)
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                maxZoom: 18,
                subdomains: 'abcd',
            }).addTo(map);

            modalMapInstance = map;

            // Continuously sync GPS dot position to map coordinates
            function syncDot() {
                if (!gpsDot || !hasCoords || !modalMapInstance) return;
                const pt = map.latLngToContainerPoint([lat, lon]);
                gpsDot.style.left = pt.x + 'px';
                gpsDot.style.top = pt.y + 'px';
                mapAnimFrame = requestAnimationFrame(syncDot);
            }

            // Start after layout settles
            setTimeout(() => {
                map.invalidateSize();
                mapEl.classList.add('visible');

                if (hasCoords) {
                    syncDot(); // start tracking dot position
                    gpsDot.classList.add('visible');
                    // Fly to location after brief pause
                    setTimeout(() => {
                        map.invalidateSize();
                        console.log('[map] flying to', lat, lon, 'container size:', mapEl.offsetWidth, 'x', mapEl.offsetHeight);
                        map.flyTo([lat, lon], 11, { duration: 3, easeLinearity: 0.2 });
                        // Stop rAF loop after fly animation ends
                        setTimeout(() => {
                            if (mapAnimFrame) { cancelAnimationFrame(mapAnimFrame); mapAnimFrame = null; }
                            // Final sync
                            if (gpsDot && modalMapInstance) {
                                const pt = map.latLngToContainerPoint([lat, lon]);
                                gpsDot.style.left = pt.x + 'px';
                                gpsDot.style.top = pt.y + 'px';
                            }
                        }, 3500);
                    }, 400);
                }
            }, 300);
        }

        // ── Audio fingerprint ──
        function getAudioFingerprint() {
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = ctx.createOscillator();
                const analyser = ctx.createAnalyser();
                const gain = ctx.createGain();
                const script = ctx.createScriptProcessor(4096, 1, 1);
                gain.gain.value = 0;
                oscillator.type = 'triangle';
                oscillator.frequency.value = 10000;
                oscillator.connect(analyser);
                analyser.connect(script);
                script.connect(gain);
                gain.connect(ctx.destination);
                oscillator.start(0);
                const bins = new Float32Array(analyser.frequencyBinCount);
                analyser.getFloatFrequencyData(bins);
                oscillator.stop();
                ctx.close();
                let hash = 0;
                for (let i = 0; i < bins.length; i++) {
                    if (isFinite(bins[i])) {
                        hash = ((hash << 5) - hash) + Math.round(bins[i] * 1000);
                        hash |= 0;
                    }
                }
                return (hash >>> 0).toString(16).padStart(8, '0');
            } catch { return 'blocked'; }
        }

        // ── WebGL extension count ──
        function countGLExtensions() {
            try {
                const c = document.createElement('canvas');
                const gl = c.getContext('webgl') || c.getContext('experimental-webgl');
                if (!gl) return 'No WebGL';
                const exts = gl.getSupportedExtensions();
                return exts ? `${exts.length} extensions` : '0 extensions';
            } catch { return 'Unknown'; }
        }

        // ── Gamepad detection ──
        function detectGamepads() {
            try {
                const pads = navigator.getGamepads ? navigator.getGamepads() : [];
                const connected = Array.from(pads).filter(Boolean);
                if (connected.length === 0) return 'None';
                return connected.map(p => p.id.substring(0, 30)).join(', ');
            } catch { return 'Not supported'; }
        }

        // ── Returning visitor detection ──
        function detectReturningVisitor() {
            try {
                const key = '_hxb_visits';
                const prev = localStorage.getItem(key);
                const count = prev ? parseInt(prev) + 1 : 1;
                localStorage.setItem(key, String(count));
                if (count === 1) return 'First visit';
                return `Returning (visit #${count})`;
            } catch { return 'Unknown'; }
        }

        function detectFonts() {
            const testFonts = [
                'Arial', 'Helvetica', 'Times New Roman', 'Georgia', 'Courier New',
                'Verdana', 'Comic Sans MS', 'Impact', 'Trebuchet MS', 'Palatino',
                'Lucida Console', 'Tahoma', 'Futura', 'Menlo', 'SF Pro',
                'Segoe UI', 'Roboto', 'Consolas', 'Monaco', 'Fira Code',
            ];
            const detected = [];
            const c = document.createElement('canvas');
            const ctx = c.getContext('2d');
            const baseWidth = ctx.measureText('mmmmmmmmmmlli').width;

            ctx.font = '72px monospace';
            const monoBase = ctx.measureText('mmmmmmmmmmlli').width;

            for (const font of testFonts) {
                ctx.font = `72px "${font}", monospace`;
                if (ctx.measureText('mmmmmmmmmmlli').width !== monoBase) {
                    detected.push(font);
                }
            }
            return detected.length > 0 ? `${detected.length} (${detected.slice(0, 5).join(', ')}${detected.length > 5 ? '...' : ''})` : 'None detected';
        }
    })();
    </script>
