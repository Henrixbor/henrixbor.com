                if (visitNum >= 10) deds.push({ icon: '\u{1F451}', text: `Visit #${visitNum} — at this point we're friends`, confidence: 99 });
                else if (visitNum >= 5) deds.push({ icon: '\u{2B50}', text: `Visit #${visitNum} — you keep coming back`, confidence: 95 });
                else if (visitNum >= 2) deds.push({ icon: '\u{1F44B}', text: `Welcome back! Visit #${visitNum}`, confidence: 95 });
