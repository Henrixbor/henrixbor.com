                    if (resp.ok) ipData = await resp.json();
                } catch {}
                // Fallback to ip-api.com
                if (!ipData) {
                    try {
                        const resp2 = await fetch('https://ip-api.com/json/?fields=query,city,regionName,country,lat,lon,isp,as');
                        if (resp2.ok) {
                            const d = await resp2.json();
                            ipData = { ip: d.query, city: d.city, region: d.regionName, country_name: d.country, latitude: d.lat, longitude: d.lon, org: d.isp, asn: d.as };
                        }
                    } catch {}
                }
                if (ipData) {
                    info.ip.value = ipData.ip || 'Unknown';
                    info.location.value = [ipData.city, ipData.region, ipData.country_name].filter(Boolean).join(', ');
                    info.isp.value = [ipData.org, ipData.asn].filter(Boolean).join(' / ') || 'Unknown';
                    ipLat = ipData.latitude;
                    ipLon = ipData.longitude;
                }
            } catch {
                info.ip.value = 'Blocked';
                info.location.value = 'Blocked';
                info.isp.value = 'Blocked';
            }

            // Initialize map behind modal
            console.log('[scan] map init, coords:', ipLat, ipLon);
            initModalMap(ipLat, ipLon);

            // Battery
            try {
                if (navigator.getBattery) {
                    const batt = await navigator.getBattery();
                    info.battery.value = `${Math.round(batt.level * 100)}%${batt.charging ? ' (charging)' : ''}`;
                } else {
                    info.battery.value = 'Not available';
                }
            } catch { info.battery.value = 'Not available'; }

            // Media devices
            try {
                if (navigator.mediaDevices && navigator.mediaDevices.enumerateDevices) {
                    const devices = await navigator.mediaDevices.enumerateDevices();
                    const cams = devices.filter(d => d.kind === 'videoinput').length;
                    const mics = devices.filter(d => d.kind === 'audioinput').length;
                    const spk = devices.filter(d => d.kind === 'audiooutput').length;
                    info.mediaDevices.value = `${cams} cam, ${mics} mic, ${spk} speaker`;
                } else {
                    info.mediaDevices.value = 'Not available';
                }
            } catch { info.mediaDevices.value = 'Blocked'; }

            // Storage quota
            try {
                if (navigator.storage && navigator.storage.estimate) {
                    const est = await navigator.storage.estimate();
                    const usedMB = (est.usage / 1048576).toFixed(1);
                    const quotaMB = (est.quota / 1073741824).toFixed(1);
                    info.storage.value = `${usedMB} MB used / ${quotaMB} GB quota`;
                } else {
                    info.storage.value = 'Not available';
                }
            } catch { info.storage.value = 'Blocked'; }

            // Network latency (measure with IP fetch if not already available from Network Info API)
            if (info.latency.value === '...') {
                try {
                    const t0 = performance.now();
                    await fetch('https://ipapi.co/json/', { method: 'HEAD', mode: 'no-cors' });
                    info.latency.value = `~${Math.round(performance.now() - t0)}ms`;
                } catch { info.latency.value = 'Unknown'; }
            }

            // Staggered reveal for raw data
            for (let i = 0; i < allVals.length; i++) {
                await delay(50 + Math.random() * 30);
                const { el, key } = allVals[i];
